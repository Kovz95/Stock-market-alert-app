# Stock Market Alert App - Environment Variables Template
# Copy this file to .env and fill in your actual values

# =============================================================================
# API Keys
# =============================================================================

# Financial Modeling Prep API Key
# Get your API key from: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# =============================================================================
# Discord Webhooks
# =============================================================================

# Primary Discord webhook for alert notifications
WEBHOOK_URL=your_primary_webhook_url_here

# Secondary Discord webhook for alert notifications
WEBHOOK_URL_2=your_secondary_webhook_url_here

# Discord webhook for application logging
WEBHOOK_URL_LOGGING=your_logging_webhook_url_here

# Secondary Discord webhook for application logging
WEBHOOK_URL_LOGGING_2=your_secondary_logging_webhook_url_here

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL database URL (if different from default in db_config)
# DATABASE_URL=postgresql://user:password@localhost:5432/stock_alerts

# Redis URL for caching (if using Redis)
# REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Application Settings
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (true/false)
DEBUG=false

# =============================================================================
# Interactive Brokers (if applicable)
# =============================================================================

# IB Gateway/TWS connection settings
# IB_HOST=127.0.0.1
# IB_PORT=7497
# IB_CLIENT_ID=1
